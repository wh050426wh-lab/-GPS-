def find_nearest_vehicle(df, click_lat, click_lng):
    if len(df) == 0:
        return None
    distances = np.sqrt((df['lati'] - click_lat) ** 2 + (df['long'] - click_lng) ** 2)
    return df.loc[distances.idxmin()]


# ── Canvas 原点图层 ───────────────────────────────────────────────────

class CanvasDotsLayer(MacroElement):
    _template = Template("""
    {% macro script(this, kwargs) %}
    (function(){
        var PTS_SNAPSHOT = {{ this.snapshot_points_json }};
        var mapObj = {{ this._parent.get_name() }};

        var showBusy = true, showIdle = true;
        var cvs = document.createElement('canvas');
        cvs.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:200;';
        mapObj.getPanes().overlayPane.appendChild(cvs);

        function redraw(){
            var size = mapObj.getSize();
            cvs.width  = size.x;
            cvs.height = size.y;
            var tl  = mapObj.containerPointToLayerPoint([0,0]);
            cvs.style.left = tl.x + 'px';
            cvs.style.top  = tl.y + 'px';
            var ctx = cvs.getContext('2d');
            ctx.clearRect(0, 0, cvs.width, cvs.height);
            var zoom = mapObj.getZoom();
            var r = Math.max(2, Math.min(6, zoom - 7));

            if(showBusy || showIdle){
                for(var k=0; k<PTS_SNAPSHOT.length; k++){
                    var p = PTS_SNAPSHOT[k];
                    if(p.s===1 && !showBusy) continue;
                    if(p.s===0 && !showIdle) continue;
                    if(window._animPlaying && window._animVehicleId && p.i===window._animVehicleId) continue;
                    var pt = mapObj.latLngToContainerPoint([p.a, p.o]);
                    ctx.beginPath();
                    ctx.arc(pt.x, pt.y, r, 0, 2*Math.PI);
                    ctx.fillStyle = p.s===1 ? '#E63946' : '#06D6A0';
                    ctx.globalAlpha = 0.55;
                    ctx.fill();
                    ctx.strokeStyle = 'rgba(255,255,255,0.6)';
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            }

            var animPos = window._animPosition;
            if(animPos){
                var s = window._animStatus || 0;
                var pt = mapObj.latLngToContainerPoint([animPos.lat, animPos.lng]);
                ctx.beginPath();
                ctx.arc(pt.x, pt.y, r*2.5, 0, 2*Math.PI);
                ctx.fillStyle = s===1 ? '#E63946' : '#06D6A0';
                ctx.globalAlpha = 0.3;
                ctx.fill();
                ctx.beginPath();
                ctx.arc(pt.x, pt.y, r*1.5, 0, 2*Math.PI);
                ctx.fillStyle = s===1 ? '#E63946' : '#06D6A0';
                ctx.globalAlpha = 0.95;
                ctx.fill();
                ctx.strokeStyle = 'white';
                ctx.lineWidth = 2;
                ctx.globalAlpha = 1.0;
                ctx.stroke();
            }
        }

        mapObj.on('moveend zoomend resize viewreset', redraw);
        redraw();

        mapObj.on('overlayadd overlayremove', function(e){
            if(e.name==='载客车辆(快照)') showBusy = (e.type==='overlayadd');
            if(e.name==='空载车辆(快照)') showIdle = (e.type==='overlayadd');
            redraw();
        });

        window._animPlaying = false;
        window._animVehicleId = null;
        window._animPosition = null;
        window._animStatus = 0;
        window._animSpeed = 0;

        window._updateAnimPosition = function(lat, lng, status, speed, vehicleId){
            window._animPlaying = true;
            window._animVehicleId = vehicleId;
            window._animPosition = {lat:lat, lng:lng};
            window._animStatus = status;
            window._animSpeed = speed;
            redraw();
        };

        window._stopAnimation = function(){
            window._animPlaying = false;
            window._animVehicleId = null;
            window._animPosition = null;
            window._animStatus = 0;
            window._animSpeed = 0;
            redraw();
        };
    })();
    {% endmacro %}
    """)

    def __init__(self, snapshot_points_json):
        super().__init__()
        self._name = 'CanvasDotsLayer'
        self.snapshot_points_json = snapshot_points_json


def build_fleet_map(df_snapshot, highlight_row=None):
    """构建全车快照地图"""
    if len(df_snapshot) == 0:
        return None

    map_center = SHENZHEN_CENTER
    zoom = 11
    if highlight_row is not None:
        map_center = [highlight_row['lati'], highlight_row['long']]
        zoom = 14

    m = folium.Map(location=map_center, zoom_start=zoom,
                   tiles='OpenStreetMap', prefer_canvas=True)

    folium.FeatureGroup(name='载客车辆(快照)', show=True).add_to(m)
    folium.FeatureGroup(name='空载车辆(快照)', show=True).add_to(m)

    records = df_snapshot[['lati', 'long', 'status', 'id', 'speed']].copy()
    records['id'] = records['id'].astype(int)
    pts = [{'a': r.lati, 'o': r.long, 's': int(r.status),
            'i': int(r.id), 'v': float(r.speed)}
           for r in records.itertuples()]
    CanvasDotsLayer(json.dumps(pts)).add_to(m)

    if highlight_row is not None:
        fg_hl = folium.FeatureGroup(name='定位车辆', show=True)
        folium.Marker(
            location=[highlight_row['lati'], highlight_row['long']],
            popup=folium.Popup(
                f"<b>车辆 {int(highlight_row['id'])}</b><br>"
                f"状态：{'载客' if highlight_row['status'] == 1 else '空载'}<br>"
                f"速度：{highlight_row['speed']} km/h", max_width=200),
            icon=folium.Icon(color='red', icon='star'),
        ).add_to(fg_hl)
        fg_hl.add_to(m)

    boundary = load_shenzhen_boundary()
    fg_boundary = folium.FeatureGroup(name='深圳市边界', show=True)
    add_boundary_to_map(fg_boundary, boundary)
    fg_boundary.add_to(m)

    folium.LayerControl(collapsed=False).add_to(m)
    return m


