    anim_start = traj['time'].min()
    traj_pts = []
    for _, r in traj.iterrows():
        elapsed = (r['time'] - anim_start).total_seconds()
        traj_pts.append({
            'lat': float(r['lati']), 'lng': float(r['long']),
            'status': int(r['status']), 'speed': float(r['speed']),
            'time': r['time'].strftime('%H:%M:%S'),
            'elapsed': float(elapsed),
        })

    color = MULTI_VEHICLE_COLORS[0]
    traj_static = [[float(r['lati']), float(r['long'])] for _, r in traj.iterrows()]

    traj_segments = []
    current_seg = []
    current_status = None
    for _, r in traj.iterrows():
        s = int(r['status'])
        if s != current_status:
            if current_seg:
                traj_segments.append({'status': current_status, 'points': current_seg})
            current_seg = []
            current_status = s
        current_seg.append([float(r['lati']), float(r['long'])])
    if current_seg:
        traj_segments.append({'status': current_status, 'points': current_seg})

