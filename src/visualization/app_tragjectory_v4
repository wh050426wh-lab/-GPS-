class CanvasDotsLayer(MacroElement):
    """
    用 MacroElement 把 Canvas 绘点脚本内嵌进 folium 生成的 HTML。
    脚本与地图在同一文档，map 对象一定存在，无跨 iframe 时序问题。
    载客红色 #E63946，空载绿色 #06D6A0。
    支持图层控制面板开关（overlayadd/overlayremove）。
    点击地图弹出最近车辆 popup。
    """
    _template = Template("""
    {% macro script(this, kwargs) %}
    (function(){
        var PTS = {{ this.points_json }};
        var mapObj = {{ this._parent.get_name() }};

        /* Canvas Layer */
        var showBusy = true, showIdle = true;
        var cvs = document.createElement('canvas');
        cvs.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;';
        mapObj.getPanes().overlayPane.appendChild(cvs);

        function redraw(){
            var size = mapObj.getSize();
            cvs.width  = size.x;
            cvs.height = size.y;
            var tl  = mapObj.containerPointToLayerPoint([0,0]);
            cvs.style.left = tl.x + 'px';
            cvs.style.top  = tl.y + 'px';
            var ctx = cvs.getContext('2d');
            ctx.clearRect(0, 0, cvs.width, cvs.height);
            var zoom = mapObj.getZoom();
            var r = Math.max(2, Math.min(6, zoom - 7));
            for(var k=0; k<PTS.length; k++){
                var p = PTS[k];
                if(p.s===1 && !showBusy) continue;
                if(p.s===0 && !showIdle) continue;
                var pt = mapObj.latLngToContainerPoint([p.a, p.o]);
                ctx.beginPath();
                ctx.arc(pt.x, pt.y, r, 0, 2*Math.PI);
                ctx.fillStyle = p.s===1 ? '#E63946' : '#06D6A0';
                ctx.globalAlpha = 0.80;
                ctx.fill();
            }
        }

        mapObj.on('moveend zoomend resize viewreset', redraw);
        redraw();

        /* 图层控制联动 */
        mapObj.on('overlayadd overlayremove', function(e){
            if(e.name==='载客轨迹') showBusy = (e.type==='overlayadd');
            if(e.name==='空载轨迹') showIdle = (e.type==='overlayadd');
            redraw();
        });

        /* 点击弹出最近车辆 popup */
        mapObj.on('click', function(e){
            var clat=e.latlng.lat, clng=e.latlng.lng;
            var best=null, bestD=Infinity;
            var bounds=mapObj.getBounds();
            for(var k=0;k<PTS.length;k++){
                var p=PTS[k];
                if(!bounds.contains([p.a,p.o])) continue;
                var d=(p.a-clat)*(p.a-clat)+(p.o-clng)*(p.o-clng);
                if(d<bestD){bestD=d;best=p;}
            }
            if(best){
                L.popup()
                 .setLatLng([best.a,best.o])
                 .setContent(
                    '<b>车辆id: '+best.i+'</b><br>'+
                    '状态: '+(best.s===1?'🔴 载客':'🟢 空载')+'<br>'+
                    '速度: '+best.v+' km/h'
                 ).openOn(mapObj);
            }
        });
    })();
    {% endmacro %}
    """)

    def __init__(self, points_json):
        super().__init__()
        self._name = 'CanvasDotsLayer'
        self.points_json = points_json


def build_fleet_snapshot_map(df, highlight_row=None, bbox=None, enable_draw=True):
    if len(df) == 0:
        return None

    map_center = ([highlight_row['lati'], highlight_row['long']]
                  if highlight_row is not None else SHENZHEN_CENTER)
    zoom = 14 if highlight_row is not None else 11

    # prefer_canvas=True 让 Leaflet 用 Canvas renderer 处理矢量层，进一步减少 DOM 压力
    m = folium.Map(location=map_center, zoom_start=zoom,
                   tiles='OpenStreetMap', prefer_canvas=True)

    # 两个空 FeatureGroup 仅用于图层控制面板显示开关，实际渲染由 CanvasDotsLayer 负责
    folium.FeatureGroup(name='载客轨迹', show=True).add_to(m)
    folium.FeatureGroup(name='空载轨迹', show=True).add_to(m)

    # 序列化点数据（字段名缩短减少 JSON 体积）
    records = df[['lati', 'long', 'status', 'id', 'speed']].copy()
    records['id'] = records['id'].astype(int)
    pts = [{'a': r.lati, 'o': r.long, 's': int(r.status),
             'i': int(r.id), 'v': float(r.speed)}
           for r in records.itertuples()]
    points_json = json.dumps(pts)

    # Canvas 绘点层内嵌进地图 HTML
    CanvasDotsLayer(points_json).add_to(m)

    # 高亮搜索车辆
    if highlight_row is not None:
        fg_hl = folium.FeatureGroup(name='起点/终点', show=True)
        folium.Marker(
            location=[highlight_row['lati'], highlight_row['long']],
            popup=folium.Popup(
                f"<b>车辆 {int(highlight_row['id'])}</b><br>"
                f"状态：{'载客' if highlight_row['status']==1 else '空载'}<br>"
                f"速度：{highlight_row['speed']} km/h", max_width=200),
            icon=folium.Icon(color='red', icon='star'),
            tooltip=f"车辆 {int(highlight_row['id'])}（已定位）",
        ).add_to(fg_hl)
        fg_hl.add_to(m)

    # 框选范围静态显示
    if bbox is not None:
        south, north, west, east = bbox
        folium.Rectangle(
            bounds=[[south, west], [north, east]],
            color='#9b5de5', weight=2.5, fill=True,
            fill_color='#9b5de5', fill_opacity=0.06,
            dash_array='6,4', tooltip='当前框选范围',
        ).add_to(m)

    # 深圳边界
    boundary = load_shenzhen_boundary()
    fg_boundary = folium.FeatureGroup(name='深圳市边界', show=True)
    add_boundary_to_map(fg_boundary, boundary)
    fg_boundary.add_to(m)

    # 框选工具
    if enable_draw:
        Draw(
            export=False,
            draw_options={
                'polyline': False, 'polygon': False, 'circle': False,
                'marker': False, 'circlemarker': False,
                'rectangle': {'shapeOptions': {'color': '#9b5de5'}},
            },
            edit_options={'edit': False, 'remove': True},
        ).add_to(m)

    folium.LayerControl(collapsed=False).add_to(m)
    return m


