# ── Tab 3（原 Tab4）：多车轨迹动画对比 ───────────────────────────────

def build_multi_vehicle_animation_html(vehicle_dfs, color_map, start_time, road_match=False):
    vehicle_dfs = {vid: df for vid, df in vehicle_dfs.items() if len(df) > 0}
    if not vehicle_dfs:
        return None

    all_lats = pd.concat([df['lati'] for df in vehicle_dfs.values()])
    all_lons = pd.concat([df['long'] for df in vehicle_dfs.values()])
    m = folium.Map(location=[all_lats.mean(), all_lons.mean()],
                   zoom_start=12, tiles='OpenStreetMap')

    vehicles_payload = []
    max_elapsed = 0.0

    for vid, df in vehicle_dfs.items():
        color = color_map.get(vid, '#333333')
        df = df.copy()
        df['status_grp'] = (df['status'] != df['status'].shift()).cumsum()

        fg_busy   = folium.FeatureGroup(name=f'车辆{vid}·载客轨迹', show=True)
        fg_idle   = folium.FeatureGroup(name=f'车辆{vid}·空载轨迹', show=True)
        fg_pickup = folium.FeatureGroup(name=f'车辆{vid}·上车点',   show=True)
        fg_drop   = folium.FeatureGroup(name=f'车辆{vid}·下车点',   show=True)
        fg_ep     = folium.FeatureGroup(name=f'车辆{vid}·起点/终点',show=True)

        for _, seg in df.groupby('status_grp'):
            if len(seg) < 2:
                continue
            pts = seg[['lati', 'long']].values.tolist()
            if seg['status'].iloc[0] == 1:
                folium.PolyLine(pts, color=color, weight=3, opacity=0.35,
                                dash_array='4,6', tooltip=f'车辆{vid}·载客').add_to(fg_busy)
            else:
                folium.PolyLine(pts, color=color, weight=2, opacity=0.25,
                                dash_array='2,8', tooltip=f'车辆{vid}·空载').add_to(fg_idle)

        df['status_prev'] = df['status'].shift(1)
        for _, row in df[(df['status'] == 1) & (df['status_prev'] == 0)].iterrows():
            folium.CircleMarker([row['lati'], row['long']], radius=5,
                                color=color, fill=True, fill_color='white',
                                fill_opacity=0.9, weight=2.5,
                                popup=f"上车 {row['time']}").add_to(fg_pickup)
        for _, row in df[(df['status'] == 0) & (df['status_prev'] == 1)].iterrows():
            folium.CircleMarker([row['lati'], row['long']], radius=5,
                                color=color, fill=True, fill_color=color,
                                fill_opacity=0.7, weight=2,
                                popup=f"下车 {row['time']}").add_to(fg_drop)

        folium.Marker([df.iloc[0]['lati'],  df.iloc[0]['long']],
                      popup=f"起点 {df.iloc[0]['time']}",
                      icon=folium.Icon(color='blue', icon='home')).add_to(fg_ep)
        folium.Marker([df.iloc[-1]['lati'], df.iloc[-1]['long']],
                      popup=f"终点 {df.iloc[-1]['time']}",
                      icon=folium.Icon(color='black', icon='flag')).add_to(fg_ep)

        for fg in (fg_busy, fg_idle, fg_pickup, fg_drop, fg_ep):
            fg.add_to(m)

        df = df.reset_index(drop=True)
        pts_payload = []
        for _, row in df.iterrows():
            elapsed = (row['time'] - start_time).total_seconds()
            pts_payload.append({
                'lat': row['lati'], 'lng': row['long'],
                'status': int(row['status']), 'speed': float(row['speed']),
                'time': row['time'].strftime('%H:%M:%S'),
                'elapsed': float(elapsed),
            })
        if pts_payload:
            max_elapsed = max(max_elapsed, pts_payload[-1]['elapsed'])
        vehicles_payload.append({'id': vid, 'color': color, 'points': pts_payload})

    boundary = load_shenzhen_boundary()
    fg_boundary = folium.FeatureGroup(name='深圳市边界', show=True)
    add_boundary_to_map(fg_boundary, boundary)
    fg_boundary.add_to(m)
    folium.LayerControl(collapsed=False).add_to(m)
    add_road_match_banner(m, road_match)

    target_play_seconds = 25
    time_scale = (max_elapsed / target_play_seconds) if max_elapsed > 0 else 1.0
    vehicles_json = json.dumps(vehicles_payload)
    map_var = m.get_name()

    legend_rows = ''.join(
        f'<div><span style="display:inline-block;width:14px;height:14px;border-radius:50%;'
        f'background:{v["color"]};vertical-align:middle;margin-right:6px;"></span>车辆 {v["id"]}</div>'
        for v in vehicles_payload
    )
    status_rows = ''.join(
        f'<div id="status-{v["id"]}" style="margin-bottom:2px;">车辆{v["id"]}：等待播放</div>'
        for v in vehicles_payload
    )

    anim = f'''
    <div id="ctrl" style="position:fixed;bottom:30px;right:20px;z-index:9999;
         background:rgba(255,255,255,0.96);padding:12px 16px;border-radius:10px;
         box-shadow:0 2px 12px rgba(0,0,0,0.2);
         font-family:'Microsoft YaHei',sans-serif;min-width:220px;max-width:260px;">
        <div style="margin-bottom:10px;">
            <button id="playBtn" style="padding:6px 14px;font-size:14px;cursor:pointer;
                background:#2196F3;color:white;border:none;border-radius:6px;">▶ 播放对比动画</button>
            <button id="resetBtn" style="padding:6px 14px;font-size:14px;cursor:pointer;
                background:#6c757d;color:white;border:none;border-radius:6px;margin-left:6px;">⟲ 重置</button>
        </div>
        <div style="width:100%;height:5px;background:#e9ecef;border-radius:3px;margin-bottom:8px;">
            <div id="prog" style="height:100%;width:0%;background:#2196F3;
                 border-radius:3px;transition:width 0.1s;"></div>
        </div>
        <div style="border-top:1px solid #e9ecef;margin:6px 0 8px;"></div>
        <div style="font-size:12px;color:#333;line-height:1.7;max-height:160px;overflow-y:auto;">
            {status_rows}
        </div>
        <div style="border-top:1px solid #e9ecef;margin:8px 0 6px;"></div>
        <div style="font-size:12px;color:#333;line-height:1.8;">{legend_rows}</div>
    </div>
    <script>
    (function(){{
        var vehicles={vehicles_json};
        var timeScale={time_scale}, maxElapsed={max_elapsed};
        var tickMs=50, playMs=0, ticker=null;
        function waitMap(){{
            if(typeof {map_var}==='undefined'){{setTimeout(waitMap,100);return;}}
            var M={map_var};
            vehicles.forEach(function(v){{
                var html='<div style="width:22px;height:22px;border-radius:50%;border:3px solid '+
                    v.color+';background:white;display:flex;align-items:center;'+
                    'justify-content:center;font-size:12px;">🚕</div>';
                v.marker=L.marker([v.points[0].lat,v.points[0].lng],
                    {{icon:L.divIcon({{html:html,iconSize:[22,22],className:''}})}}).addTo(M);
                v.trail=L.polyline([],{{color:v.color,weight:5,opacity:0.92}}).addTo(M);
                v.idx=0;
                v.el=document.getElementById('status-'+v.id);
            }});
            var prog=document.getElementById('prog');
            var playBtn=document.getElementById('playBtn');
            function done(){{return vehicles.every(function(v){{return v.idx>=v.points.length;}});}}
            function tick(){{
                playMs+=tickMs;
                var re=(playMs/1000)*timeScale;
                vehicles.forEach(function(v){{
                    while(v.idx<v.points.length&&v.points[v.idx].elapsed<=re){{
                        var p=v.points[v.idx];
                        v.marker.setLatLng([p.lat,p.lng]);
                        v.trail.addLatLng([p.lat,p.lng]);
                        if(v.el)v.el.innerHTML='<b>车辆'+v.id+'</b>：'+p.time+
                            ' · '+(p.status===1?'🔴载客':'🟢空载')+' · '+p.speed+'km/h';
                        v.idx++;
                    }}
                }});
                prog.style.width=Math.min(100,(re/maxElapsed*100))+'%';
                if(re>=maxElapsed||done()){{
                    clearInterval(ticker);ticker=null;
                    playBtn.innerText='✅ 播放完成';prog.style.width='100%';
                }}
            }}
            playBtn.onclick=function(){{
                if(ticker)return;
                this.innerText='⏸ 播放中...';
                ticker=setInterval(tick,tickMs);
            }};
            document.getElementById('resetBtn').onclick=function(){{
                clearInterval(ticker);ticker=null;playMs=0;
                vehicles.forEach(function(v){{
                    v.idx=0;
                    v.marker.setLatLng([v.points[0].lat,v.points[0].lng]);
                    v.trail.setLatLngs([]);
                    if(v.el)v.el.innerHTML='车辆'+v.id+'：等待播放';
                }});
                prog.style.width='0%';playBtn.innerText='▶ 播放对比动画';
            }};
        }}
        waitMap();
    }})();
    </script>'''

    return m.get_root().render() + anim


